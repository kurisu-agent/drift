# Circuit image used by the integration harness. The goal is "as close to a
# real lakitu-hosting circuit as docker-in-docker can manage" without pulling
# in a full desktop OS.
#
# Layers:
#   - Debian slim + openssh-server + the subset of userland lakitu calls
#     out to (git, gh via curl, yaml.v3 via Go stdlib — nothing extra here).
#   - A non-root user `circuit` in the `docker` group so devpod's docker
#     provider can talk to the DinD sidecar the harness mounts in.
#   - The test-built `lakitu` binary, copied in at build time.
#   - The test-installed `devpod` binary. Pinning a version here keeps the
#     integration suite deterministic — production circuits install it out
#     of band per plans/PLAN.md § "Bootstrap / install".
#
# sshd runs as PID 1; the harness connects over the forwarded port and
# drives `lakitu rpc` through the same SSH transport drift uses in
# production.
FROM debian:bookworm-slim

ARG DEVPOD_VERSION=v0.22.0
ARG DOCKER_CLI_VERSION=28.5.2
ARG LAKITU_PATH=./lakitu
ARG CIRCUIT_USER=circuit
ARG CIRCUIT_UID=1000

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      openssh-server \
      ca-certificates \
      curl \
      git \
      sudo \
      dumb-init \
      netcat-openbsd \
 && rm -rf /var/lib/apt/lists/* \
 && mkdir -p /run/sshd \
 && sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config \
 && sed -i 's/^#*PubkeyAuthentication.*/PubkeyAuthentication yes/' /etc/ssh/sshd_config \
 && sed -i 's/^#*PermitRootLogin.*/PermitRootLogin no/' /etc/ssh/sshd_config \
 # PermitUserEnvironment + AcceptEnv so the harness can pin TMPDIR (shared
 # bind mount path) via ~/.ssh/environment for lakitu-over-ssh sessions.
 && printf 'PermitUserEnvironment yes\nAcceptEnv TMPDIR\n' >> /etc/ssh/sshd_config

# Install the docker CLI (static binary; no daemon). devpod's docker provider
# talks to the bind-mounted host socket, so only the client is needed inside
# the image. Pinning the version keeps the integration suite deterministic.
RUN arch="$(dpkg --print-architecture)" \
 && case "$arch" in \
      amd64) docker_arch=x86_64 ;; \
      arm64) docker_arch=aarch64 ;; \
      *) echo "unsupported arch: $arch" >&2; exit 1 ;; \
    esac \
 && curl -L -o /tmp/docker.tgz "https://download.docker.com/linux/static/stable/${docker_arch}/docker-${DOCKER_CLI_VERSION}.tgz" \
 && tar -xzf /tmp/docker.tgz -C /usr/local/bin --strip-components=1 docker/docker \
 && rm /tmp/docker.tgz

# Install devpod. The harness runs circuit containers as siblings of the
# devcontainer's outer docker — the devpod provider inside circuit talks to
# the shared daemon via a bind-mounted /var/run/docker.sock.
RUN arch="$(dpkg --print-architecture)" \
 && curl -fL -o /usr/local/bin/devpod \
      "https://github.com/skevetter/devpod/releases/download/${DEVPOD_VERSION}/devpod-linux-${arch}" \
 && chmod +x /usr/local/bin/devpod

# Non-root circuit user mirrors the production install pattern: sshd drops
# to this UID on login, lakitu runs as it, and ~/.drift/garage lives under
# its HOME.
RUN useradd --create-home --uid "${CIRCUIT_UID}" --shell /bin/bash "${CIRCUIT_USER}" \
 && mkdir -p "/home/${CIRCUIT_USER}/.ssh" \
 && chmod 0700 "/home/${CIRCUIT_USER}/.ssh" \
 && chown -R "${CIRCUIT_USER}:${CIRCUIT_USER}" "/home/${CIRCUIT_USER}"

COPY "${LAKITU_PATH}" /usr/local/bin/lakitu
RUN chmod +x /usr/local/bin/lakitu

EXPOSE 22
ENTRYPOINT ["/usr/bin/dumb-init", "--"]
CMD ["/usr/sbin/sshd", "-D", "-e"]
