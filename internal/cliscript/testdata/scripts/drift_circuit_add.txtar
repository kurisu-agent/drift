# `drift circuit add` registers a circuit, updates the client config,
# and writes the managed SSH config blocks per plans/PLAN.md.

# Sanity — clean slate under $HOME (cliscript points HOME at the workdir).
! exists $HOME/.config/drift/config.yaml
! exists $HOME/.config/drift/ssh_config
! exists $HOME/.ssh/config

drift circuit add my-server --host dev@my-server.example.com --no-probe
stdout 'registered circuit "my-server"'
stdout 'set as default circuit'
stdout 'wrote SSH config block drift.my-server'
! stderr .

# Client config now carries the circuit and the default pointer.
exists $HOME/.config/drift/config.yaml
grep 'default_circuit: my-server' $HOME/.config/drift/config.yaml
grep 'host: dev@my-server.example.com' $HOME/.config/drift/config.yaml

# Managed ssh_config holds the full block from plans/PLAN.md.
exists $HOME/.config/drift/ssh_config
grep '^Host drift.my-server$' $HOME/.config/drift/ssh_config
grep '  HostName my-server.example.com' $HOME/.config/drift/ssh_config
grep '  User dev' $HOME/.config/drift/ssh_config
grep '  ControlMaster auto' $HOME/.config/drift/ssh_config
grep '^Host drift\.\*\.\*$' $HOME/.config/drift/ssh_config

# User ssh_config now has the Include line at the top (file was created).
exists $HOME/.ssh/config
grep '^Include ~/.config/drift/ssh_config' $HOME/.ssh/config

# List shows the circuit.
drift circuit list
stdout 'my-server'
stdout 'dev@my-server.example.com'

# JSON output shape.
drift --output json circuit list
stdout '"circuits"'
stdout '"default_circuit":"my-server"'

# Adding a second circuit does not become default unless --default.
drift circuit add other --host bob@other.example.com --no-probe
drift circuit list
stdout 'my-server'
stdout 'other'
grep 'default_circuit: my-server' $HOME/.config/drift/config.yaml

# Re-adding the same circuit is idempotent — block is replaced in place.
drift circuit add my-server --host dev@my-server.example.com --no-probe
! stderr .
grep '  HostName my-server.example.com' $HOME/.config/drift/ssh_config
