# `drift warmup` requires a TTY on stdin — testscript pipes stdin, so the
# wizard must refuse with a user_error (exit code 2) per plans/PLAN.md
# § drift warmup.

! drift warmup
stderr 'requires a TTY'

# Re-check with --skip-circuits alone — still a TTY-gated flow.
! drift warmup --skip-circuits
stderr 'requires a TTY'

# Client config must NOT have been created or mutated by the refusal path.
! exists $HOME/.config/drift/config.yaml
