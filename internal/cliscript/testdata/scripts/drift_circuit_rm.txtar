# `drift circuit rm` removes a circuit from config and its SSH block,
# but leaves the Include line in ~/.ssh/config alone.

drift circuit add a --host dev@a.example.com --no-probe
drift circuit add b --host dev@b.example.com --no-probe

grep '^Host drift.a$' $HOME/.config/drift/ssh_config
grep '^Host drift.b$' $HOME/.config/drift/ssh_config
grep '^Include ~/.config/drift/ssh_config' $HOME/.ssh/config

drift circuit rm a
stdout 'removed circuit "a"'
! stderr .

# a is gone from config and from ssh_config.
! grep '^Host drift.a$' $HOME/.config/drift/ssh_config
grep '^Host drift.b$' $HOME/.config/drift/ssh_config

# The Include line survives — b still needs it.
grep '^Include ~/.config/drift/ssh_config' $HOME/.ssh/config

# Default circuit pointer was cleared since we removed the default.
! grep 'default_circuit: a' $HOME/.config/drift/config.yaml

# Removing a missing circuit is a user error.
! drift circuit rm a
stderr 'not found'
